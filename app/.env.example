# Copy to .env.local and fill in. EXPO_PUBLIC_* values are bundled into the app
# (the anon key is a public client key — safe to ship; protected by RLS).
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Flip to "true" to use the live Supabase backend instead of the in-memory mock.
# (Spots cutover is partial — see docs/BACKEND_INTEGRATION_TODO.md.)
EXPO_PUBLIC_USE_SUPABASE=false
